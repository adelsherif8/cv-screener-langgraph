# Copy to .env and fill in. With no keys, everything runs in deterministic
# MOCK mode (no network, no cost, no real traces) so the demo still works.

# --- OpenAI (required for real model calls + real metrics) ---
OPENAI_API_KEY=sk-...

# --- Langfuse (required for live traces; free cloud tier at cloud.langfuse.com) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com   # or https://us.cloud.langfuse.com

# --- Which profile the graph runs by default (baseline | optimized) ---
CV_PROFILE=optimized
